    "version": "0.2.0",
    "configurations": [
        {
            "name": "Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            }
        },
        {
            "name": "Webui",
            "type": "debugpy",
            "request": "launch",
            "program": "webui.py",
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Webui: Single GPU",
            "type": "debugpy",
            "request": "launch",
            "program": "webui.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "justMyCode": false
        },
        {
            "name": "Infer Chat CML 0.5B",
            "type": "debugpy",
            "request": "launch",
            "program": "infer_cmd.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--model-path",
                "models/hf/Qwen1.5-0.5B-Chat"
            ]
        },
        {
            "name": "Infer with LORA 1.8B",
            "type": "debugpy",
            "request": "launch",
            "program": "lora/infer_with_lora.py",
            "console": "integratedTerminal",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--model-path",
                "models/hf/Qwen1.5-1.8B-Chat",
                "--lora-path",
                "~/workspace/github/Qwen1.5/examples/sft/output_qwen"
            ],
            "justMyCode": false
        },
        {
            "name": "API: Run server Mixtral",
            "type": "debugpy",
            "request": "launch",
            "program": "openai_api.py",
            "console": "integratedTerminal",
            "args": [
                "--checkpoint-path",
                "models/hf/Mixtral-8x7B-Instruct-v0.1-GPTQ"
            ],
            "justMyCode": false
        },
        {
            "name": "API: Run experimental",
            "type": "debugpy",
            "request": "launch",
            "program": "openai_api_experimental.py",
            "console": "integratedTerminal",
            "args": [
                "--checkpoint-path",
                "models/hf/qwen1_5-14b-chat-q5_0.gguf"
            ],
            "justMyCode": false
        }
    ]
}